# ─────────────────────────────────────────────
# OpenEstimate Environment Configuration
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# ── Database ──────────────────────────────────
# SQLite (default, recommended for self-hosted single instances)
DATABASE_URL=file:./data/openestimate.db

# PostgreSQL (uncomment to use instead of SQLite)
# DATABASE_URL=postgresql://user:password@localhost:5432/openestimate

# ── Authentication ────────────────────────────
# Generate a strong random secret: openssl rand -base64 64
JWT_ACCESS_SECRET=change-me-to-a-random-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-random-secret-min-32-chars
# Access token TTL in seconds (default: 15 minutes)
JWT_ACCESS_TTL=900
# Refresh token TTL in seconds (default: 30 days)
JWT_REFRESH_TTL=2592000

# ── Frontend URL (used for CORS and email links) ──
CLIENT_URL=http://localhost:5173

# ── File Storage ──────────────────────────────
# Local filesystem storage (default)
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./data/uploads
# Maximum file size in bytes (default: 50MB)
MAX_FILE_SIZE=52428800

# S3-compatible storage (uncomment to use)
# STORAGE_DRIVER=s3
# S3_ENDPOINT=https://s3.amazonaws.com          # or Backblaze/MinIO endpoint
# S3_REGION=us-east-1
# S3_BUCKET=openestimate-files
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_FORCE_PATH_STYLE=false                     # set true for MinIO

# ── Email / SMTP ──────────────────────────────
# Leave blank to disable email notifications entirely
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false                               # true for port 465
SMTP_USER=
SMTP_PASS=
SMTP_FROM="OpenEstimate <noreply@yourcompany.com>"

# ── Client (Vite) ─────────────────────────────
# These are injected into the frontend build (prefix VITE_)
VITE_API_URL=http://localhost:3001
VITE_APP_VERSION=1.0.0
