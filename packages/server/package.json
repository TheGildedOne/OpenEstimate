{
  "name": "@openestimate/server",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/static": "^7.0.4",
    "@openestimate/shared": "workspace:*",
    "better-sqlite3": "^9.6.0",
    "bcryptjs": "^2.4.3",
    "crypto": "^1.0.1",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.31.2",
    "exceljs": "^4.4.0",
    "fastify": "^4.27.0",
    "mime-types": "^2.1.35",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.14",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.33.4",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.10",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.22.7",
    "tsx": "^4.15.7",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
